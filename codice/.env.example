# ─── DATABASE ────────────────────────────────────────────────────
POSTGRES_USER=sqf
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=sports_quant_fund
DATABASE_URL=postgresql+asyncpg://sqf:change_me_in_production@db:5432/sports_quant_fund

# ─── REDIS ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── AUTH ────────────────────────────────────────────────────────
SECRET_KEY=generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=giuseppe@localhost
ADMIN_PASSWORD=change_me

# ─── ANTHROPIC ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── THE ODDS API ────────────────────────────────────────────────
# https://the-odds-api.com  — Essential plan per polling continuo
ODDS_API_KEY=your_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_STALENESS_SECONDS=300   # blocca odds più vecchie di 5 minuti

# ─── API-FOOTBALL ────────────────────────────────────────────────
# RapidAPI → https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com

# ─── TENNIS API ──────────────────────────────────────────────────
# RapidAPI → Tennis Live Data
TENNIS_API_KEY=your_key_here
TENNIS_API_HOST=tennis-live-data.p.rapidapi.com

# ─── NEWS API ────────────────────────────────────────────────────
# https://newsapi.org
NEWS_API_KEY=your_key_here

# ─── TELEGRAM ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ─── BANKROLL ────────────────────────────────────────────────────
INITIAL_BANKROLL=1000.00
KELLY_MULTIPLIER=0.25
MAX_DAILY_EXPOSURE_PCT=0.12

# ─── SYSTEM ──────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
